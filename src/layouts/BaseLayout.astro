---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}

const { title = 'Interventional Neuro 2026', description = 'Clinical Reference Platform for Interventional Neurology' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
